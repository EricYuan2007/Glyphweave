---
import BaseLayout from '../layouts/BaseLayout.astro'
import PostList from '../components/PostList.astro'
import { getGlyphweavePosts } from '../lib/glyphweave'

const posts = await getGlyphweavePosts()
---

<BaseLayout title="Glyphweave Blog" description="Typst posts rendered as web-native HTML">
  <section class="page-shell" aria-labelledby="articles-heading">
    <h1 id="articles-heading" class="page-heading">Typst Articles</h1>
    <PostList {posts} />
  </section>
</BaseLayout>
