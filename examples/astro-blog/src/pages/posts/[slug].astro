---
import BaseLayout from '../../layouts/BaseLayout.astro'
import { getGlyphweavePost, getGlyphweavePosts } from '../../lib/glyphweave'

export async function getStaticPaths() {
  const posts = await getGlyphweavePosts()
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { slug: post.slug },
  }))
}

const { slug } = Astro.props
const post = await getGlyphweavePost(slug)
---

<BaseLayout title={post.title} description={post.description}>
  <p class="post-meta">{post.date}</p>
  {post.publicPdfPath && <a class="pdf-download" href={post.publicPdfPath} download>Download PDF</a>}
  <div class="post-shell">
    <article class="glyphweave-content" data-pagefind-body>
      <Fragment set:html={post.contentHtml} />
    </article>
    <aside class="toc" aria-label="Table of contents">
      <strong>Contents</strong>
      <ul>
        {post.toc.map((item) => (
          <li style={`margin-left: ${(item.depth - 1) * 0.75}rem`}>
            <a href={`#${item.id}`}>{item.title}</a>
          </li>
        ))}
      </ul>
    </aside>
  </div>
</BaseLayout>
