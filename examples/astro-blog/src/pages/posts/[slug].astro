---
import BaseLayout from '../../layouts/BaseLayout.astro'
import ArticleHeader from '../../components/ArticleHeader.astro'
import TableOfContents from '../../components/TableOfContents.astro'
import Sidenotes from '../../components/Sidenotes.astro'
import { getGlyphweavePost, getGlyphweavePosts } from '../../lib/glyphweave'

export async function getStaticPaths() {
  const posts = await getGlyphweavePosts()
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { slug: post.slug },
  }))
}

const { slug } = Astro.props
const post = await getGlyphweavePost(slug)
const articleToc = post.toc.filter((item, index) => index !== 0 || item.title !== post.title)
---

<BaseLayout title={post.title} description={post.description}>
  <div class="article-shell">
    <ArticleHeader
      title={post.title}
      description={post.description}
      date={post.date}
      tags={post.tags}
      publicPdfPath={post.publicPdfPath}
    />
    <div class="article-stage" data-article-stage>
      <TableOfContents items={articleToc} />
      <article class="glyphweave-content" data-pagefind-body>
        <Fragment set:html={post.contentHtml} />
      </article>
      <Sidenotes />
    </div>
  </div>
</BaseLayout>
