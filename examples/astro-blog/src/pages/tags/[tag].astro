---
import BaseLayout from '../../layouts/BaseLayout.astro'
import PostList from '../../components/PostList.astro'
import { getGlyphweavePosts } from '../../lib/glyphweave'

export async function getStaticPaths() {
  const posts = await getGlyphweavePosts()
  const tags = new Map()
  for (const post of posts) {
    for (const tag of post.tags) {
      const key = tag.toLowerCase()
      tags.set(key, [...(tags.get(key) ?? []), post])
    }
  }
  return [...tags.entries()].map(([tag, taggedPosts]) => ({
    params: { tag },
    props: { tag, taggedPosts },
  }))
}

const { tag, taggedPosts } = Astro.props
---

<BaseLayout title={`Tag: ${tag}`}>
  <section class="page-shell" aria-labelledby="tag-heading">
    <h1 id="tag-heading" class="page-heading">Tag: {tag}</h1>
    <PostList posts={taggedPosts} />
  </section>
</BaseLayout>
