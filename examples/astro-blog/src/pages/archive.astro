---
import BaseLayout from '../layouts/BaseLayout.astro'
import PostList from '../components/PostList.astro'
import { getGlyphweavePosts } from '../lib/glyphweave'

const posts = await getGlyphweavePosts()
---

<BaseLayout title="Archive">
  <section class="page-shell" aria-labelledby="archive-heading">
    <h1 id="archive-heading" class="page-heading">Archive</h1>
    <PostList {posts} showDescription={false} />
  </section>
</BaseLayout>
