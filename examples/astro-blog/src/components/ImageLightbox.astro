<dialog class="image-lightbox" data-image-lightbox aria-label="Image preview">
  <button class="image-lightbox__close" type="button" aria-label="Close image preview">&times;</button>
  <figure class="image-lightbox__figure">
    <img class="image-lightbox__image" alt="" data-image-lightbox-image />
    <figcaption class="image-lightbox__caption" data-image-lightbox-caption></figcaption>
  </figure>
</dialog>

<script>
  const dialog = document.querySelector<HTMLDialogElement>('[data-image-lightbox]')
  const preview = dialog?.querySelector<HTMLImageElement>('[data-image-lightbox-image]')
  const caption = dialog?.querySelector<HTMLElement>('[data-image-lightbox-caption]')
  const closeButton = dialog?.querySelector<HTMLButtonElement>('.image-lightbox__close')
  let trigger: HTMLImageElement | null = null

  const close = () => dialog?.close()

  if (dialog && preview && caption && closeButton) {
    const images = document.querySelectorAll<HTMLImageElement>('.glyphweave-content figure > img')
    for (const image of images) {
      image.tabIndex = 0
      image.setAttribute('role', 'button')
      image.setAttribute('aria-label', image.alt ? `View larger image: ${image.alt}` : 'View larger image')

      const open = () => {
        trigger = image
        preview.src = image.currentSrc || image.src
        preview.alt = image.alt
        const captionText = image.closest('figure')?.querySelector('figcaption')?.textContent?.trim() ?? ''
        caption.textContent = captionText
        caption.hidden = !captionText
        dialog.showModal()
      }

      image.addEventListener('click', open)
      image.addEventListener('keydown', (event) => {
        if (event.key === 'Enter' || event.key === ' ') {
          event.preventDefault()
          open()
        }
      })
    }

    closeButton.addEventListener('click', close)
    dialog.addEventListener('click', (event) => {
      if (event.target === dialog) close()
    })
    dialog.addEventListener('close', () => {
      preview.removeAttribute('src')
      trigger?.focus()
      trigger = null
    })
  }
</script>
