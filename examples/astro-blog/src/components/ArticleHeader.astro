---
interface Props {
  title: string
  description: string
  date: string
}

const { title, description, date } = Astro.props
---

<header class="article-header">
  <p class="article-header__eyebrow">Article</p>
  <h1>{title}</h1>
  <p class="article-header__description">{description}</p>
  <div class="article-header__meta">
    <time datetime={date}>{date}</time>
    <span aria-hidden="true">/</span>
    <span>Glyphweave</span>
  </div>
</header>
