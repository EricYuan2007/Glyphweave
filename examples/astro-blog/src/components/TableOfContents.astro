---
import type { TocItem } from '@glyphweave/schema'
import { buildTocTree } from '../lib/article-layout'
import TocTree from './TocTree.astro'

interface Props {
  items: TocItem[]
  tags: string[]
  publicPdfPath?: string
}

const { items, tags, publicPdfPath } = Astro.props
const tree = buildTocTree(items)
---

<aside class="article-toc-rail" data-article-toc>
  {items.length > 0 && (
    <nav class="article-toc" aria-labelledby="article-toc-heading">
      <p id="article-toc-heading" class="article-rail-heading">Contents</p>
      <TocTree nodes={tree} />
    </nav>
  )}

  <div class="article-rail-meta">
    {tags.length > 0 && (
      <section aria-labelledby="article-tags-heading">
        <p id="article-tags-heading" class="article-rail-heading">Tags</p>
        <ul class="article-rail-tags">
          {tags.map((tag) => <li><a href={`/tags/${tag.toLowerCase()}`}>{tag}</a></li>)}
        </ul>
      </section>
    )}
    {publicPdfPath && (
      <section aria-labelledby="article-document-heading">
        <p id="article-document-heading" class="article-rail-heading">Document</p>
        <a class="article-rail-download" href={publicPdfPath} download>Download PDF</a>
      </section>
    )}
  </div>
</aside>

<script>
  import { selectActiveHeading } from '../lib/article-layout'

  const toc = document.querySelector<HTMLElement>('[data-article-toc]')
  const links = Array.from(toc?.querySelectorAll<HTMLAnchorElement>('[data-toc-link]') ?? [])
  const headings = links
    .map((link) => document.getElementById(link.dataset.tocLink ?? ''))
    .filter((heading): heading is HTMLElement => Boolean(heading))

  let updateFrame = 0
  const updateActiveHeading = () => {
    updateFrame = 0
    const activationLine = Number.parseFloat(
      getComputedStyle(document.documentElement).getPropertyValue('--header-height'),
    ) + 88
    const activeId = selectActiveHeading(
      headings.map((heading) => ({ id: heading.id, top: heading.getBoundingClientRect().top })),
      activationLine,
    )
    for (const link of links) {
      const active = link.dataset.tocLink === activeId
      if (active) {
        link.setAttribute('aria-current', 'location')
        let parent = link.closest('details')
        while (parent) {
          parent.open = true
          parent = parent.parentElement?.closest('details') ?? null
        }
      } else {
        link.removeAttribute('aria-current')
      }
    }
  }

  const requestActiveHeadingUpdate = () => {
    if (updateFrame) return
    updateFrame = window.requestAnimationFrame(updateActiveHeading)
  }

  const observer = new IntersectionObserver(requestActiveHeadingUpdate, {
    rootMargin: '-15% 0px -70% 0px',
    threshold: [0, 1],
  })
  headings.forEach((heading) => observer.observe(heading))
  window.addEventListener('scroll', requestActiveHeadingUpdate, { passive: true })
  window.addEventListener('resize', requestActiveHeadingUpdate)
  updateActiveHeading()
</script>
