---
import '@glyphweave/astro/styles/glyphweave-math.css'

const { title, description = 'Glyphweave Astro example' } = Astro.props
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <header class="site-header">
      <a class="brand" href="/">Glyphweave Blog</a>
      <nav>
        <a href="/archive">Archive</a>
        <a href="/tags/typst">Typst</a>
      </nav>
    </header>
    <main>
      <slot />
    </main>
  </body>
</html>

<style is:global>
  :root {
    color: #1f2933;
    background: #fbfbf8;
    font-family:
      Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
  }

  body {
    margin: 0;
  }

  a {
    color: #245b74;
  }

  .site-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    max-width: 1040px;
    margin: 0 auto;
    padding: 1.25rem;
    border-bottom: 1px solid #dde4df;
  }

  .brand {
    color: #18242f;
    font-weight: 700;
    text-decoration: none;
  }

  nav {
    display: flex;
    gap: 1rem;
    font-size: 0.95rem;
  }

  main {
    max-width: 1040px;
    margin: 0 auto;
    padding: 2rem 1.25rem 4rem;
  }

  .post-list {
    display: grid;
    gap: 1rem;
    padding: 0;
    list-style: none;
  }

  .post-card {
    border-bottom: 1px solid #dde4df;
    padding: 1rem 0;
  }

  .post-card h2,
  .post-card h3 {
    margin: 0 0 0.5rem;
  }

  .post-meta,
  .tag-list {
    color: #65737e;
    font-size: 0.92rem;
  }

  .tag-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    padding: 0;
    list-style: none;
  }

  .post-shell {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 220px;
    gap: 2.5rem;
  }

  .glyphweave-content {
    font-size: 1rem;
    line-height: 1.8;
  }

  .glyphweave-content :where(h1, h2, h3, h4) {
    scroll-margin-top: 6rem;
    line-height: 1.25;
    margin-block: 2rem 0.75rem;
  }

  .glyphweave-content :where(p, ul, ol, blockquote, pre, table, figure) {
    margin-block: 1.1rem;
  }

  .glyphweave-content img {
    max-width: 100%;
    height: auto;
    border-radius: 8px;
  }

  .glyphweave-content pre {
    overflow-x: auto;
    padding: 1rem;
    background: #eef2ef;
    border-radius: 8px;
  }

  .toc {
    position: sticky;
    top: 1rem;
    align-self: start;
    font-size: 0.92rem;
  }

  .toc ul {
    list-style: none;
    padding: 0;
  }

  .toc li {
    margin: 0.45rem 0;
  }

  .pdf-download {
    display: inline-flex;
    margin: 1rem 0;
    color: #12394a;
    font-weight: 700;
  }

  @media (max-width: 760px) {
    .post-shell {
      grid-template-columns: 1fr;
    }

    .toc {
      position: static;
    }
  }
</style>
